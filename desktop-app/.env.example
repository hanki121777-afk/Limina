# ─────────────────────────────────────────────────────────
# Limina Desktop App - Environment Variables Template
# ─────────────────────────────────────────────────────────

# Supabase 프로젝트 API 주소 (Project Settings -> API -> Project URL)
VITE_SUPABASE_URL=YOUR_SUPABASE_URL

# Supabase 익명 퍼블릭 키 (Project Settings -> API -> Project API keys -> anon/public)
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Anthropic Claude API 연동 키 (데스크톱 온디바이스 AI 분석 엔진용)
VITE_ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
